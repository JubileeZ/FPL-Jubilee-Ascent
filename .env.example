# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fpl_jubilee_ascent

# FPL API SSO Credentials
FPL_EMAIL=your-email@example.com
FPL_PASSWORD=your-secure-password
# Run browser in headless mode (true/false) for authentication
FPL_HEADLESS=true

# LLM Factor Blending Configuration
# llm_weight must be a float between 0.0 and 1.0. A value of 0.0 disables LLM factor blending.
LLM_WEIGHT=0.5
LLM_API_KEY=your-llm-api-key
