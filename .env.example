# Fantasy Premier League Credentials
# Required for Playwright-based automated login
FPL_EMAIL=your_email@example.com
FPL_PASSWORD=your_password_here

# (Optional) Direct JWT Session Token
# If set and valid, overrides FPL_EMAIL and FPL_PASSWORD to skip browser login
FPL_TOKEN=

# (Optional) Playwright Browser Configuration
# Set to 'false' to run browser in windowed (non-headless) mode for debugging
FPL_HEADLESS=true
